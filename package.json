{
  "name": "task-manager-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Small Task Manager web app with Playwright E2E tests",
  "packageManager": "yarn@4.16.0",
  "scripts": {
    "start": "serve app -l 3000",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "serve": "^14.2.4",
    "typescript": "^5.8.0"
  }
}
